{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/app/browser",
  "functions": {
    "dist/app/server/server.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "dist/app/server/server.mjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "dist/app/server/server.mjs"
    }
  ]
}